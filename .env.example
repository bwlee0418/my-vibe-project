# ============================================
# CX Assistant — 환경변수 설정
# ============================================
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp .env.example .env
#
# .env 파일은 절대 GitHub에 올리지 마세요! (.gitignore에 포함됨)
# ============================================

# 서버 포트 (기본값: 3000)
PORT=3000

# AI 제공자 선택: bedrock | openai | anthropic
AI_PROVIDER=bedrock

# ── AWS Bedrock 설정 (AI_PROVIDER=bedrock 일 때) ──
AWS_ACCESS_KEY_ID=여기에_액세스_키_입력
AWS_SECRET_ACCESS_KEY=여기에_시크릿_키_입력
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ── OpenAI 설정 (AI_PROVIDER=openai 일 때) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Anthropic 설정 (AI_PROVIDER=anthropic 일 때) ──
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
